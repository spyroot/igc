# Keep the build context small and free of data/secrets/checkpoints.
.git
__pycache__/
*.pyc
*.pyo
.DS_Store
.idea/
# datasets, captures, tarballs, numpy maps — never bake into an image
datasets/
# ...but keep the small committed fixtures the offline gate loads: the slow
# tokenizer (igc_default_tokenizer_dir() -> datasets/tokenizer: vocab.json/
# merges.txt/…) and the model-specs file (igc_base_module -> datasets/models.json).
# These are the only git-tracked files under datasets/; the heavy untracked data
# (tarballs/*.npy/raw/*.pt and the big tokenizer.json) stays excluded.
!datasets/tokenizer/
!datasets/models.json
test_datasets/
tests/datasets/
*.tar.gz
*.npy
~/.json_responses
# training artifacts
experiments/
backups/
logs/
*.log
checkpoints/
datasets/*.tar.gz
datasets/dataset.json
datasets/tokenizer/tokenizer.json
test_datasets/
tests/datasets/
imgs/
# submodule (not needed for the offline gate image)
redfish_ctl/
# local agent/coordination docs (gitignored already)
COORDINATION.md
CLAUDE.md
AGENTS.md
FLASH_BRAIN.md
NV72_MODELS.md
GPU_ACCESS.md
.codex/
